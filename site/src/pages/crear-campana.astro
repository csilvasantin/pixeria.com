---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Crear campaña"
  description="Crea una campaña para un punto y pantalla concretos, previsualiza la creatividad y compra la emisión en Admira."
>
  <main class="pt-24 pb-20">
    <section class="max-w-7xl mx-auto px-6">
      <p class="text-orange font-medium mb-4">Crear campaña</p>
      <h1 class="text-5xl md:text-7xl font-semibold tracking-tight text-charcoal max-w-5xl">
        Contenido para una pantalla concreta
      </h1>
      <p class="mt-6 text-xl text-charcoal/70 max-w-3xl">
        Elige circuito, localidad, punto y pantalla; prepara el mensaje, revisa el previo y compra la emisión en Admira.
      </p>
    </section>

    <section class="campaign-shell max-w-7xl mx-auto px-6 mt-12">
      <div class="campaign-controls">
        <label class="campaign-field-circuit">
          Circuito
          <select id="circuitSel"></select>
        </label>
        <label class="campaign-field-locality">
          Localidad
          <select id="localitySel"></select>
        </label>
        <label class="campaign-field-point">
          Punto
          <select id="pointSel"></select>
        </label>
        <label class="campaign-field-screen">
          Pantalla
          <select id="screenSel"></select>
        </label>
        <label class="campaign-field-date">
          Día
          <input id="dateInp" type="date">
        </label>
      </div>

      <div class="campaign-selection" id="campaignSelectionSummary">
        Selecciona el punto de emisión para preparar el contenido.
      </div>

      <section class="campaign-workspace" id="campaignCreator">
        <div class="campaign-form">
          <h2>Contenido de campaña</h2>
          <label>
            Marca
            <input id="campaignBrand" type="text" value="Pixeria">
          </label>
          <label>
            Campaña
            <input id="campaignName" type="text">
          </label>
          <label>
            Estilo
            <select id="campaignTone">
              <option value="premium">Premium</option>
              <option value="oferta">Oferta</option>
              <option value="evento">Evento</option>
              <option value="informativo">Informativo</option>
            </select>
          </label>
          <label>
            Mensaje
            <textarea id="campaignMessage" placeholder="Nuevo lanzamiento disponible hoy"></textarea>
          </label>
          <div class="campaign-actions">
            <button class="button primary" id="campaignGenerate" type="button">Generar previo</button>
            <button class="button secondary" id="campaignBuy" type="button" disabled>Comprar en Admira</button>
          </div>
        </div>
        <div class="campaign-preview">
          <h2>Previo en pantalla</h2>
          <div class="campaign-context" id="campaignContext"></div>
          <div class="campaign-preview-frame" id="campaignPreviewFrame">
            <img id="campaignPreviewImg" alt="Previo de creatividad para la pantalla seleccionada" hidden>
            <div class="campaign-preview-empty" id="campaignPreviewEmpty">Selecciona un punto y genera el previo.</div>
          </div>
        </div>
      </section>
    </section>
  </main>

  <style is:inline>
    .campaign-controls,
    .campaign-workspace,
    .campaign-selection {
      width: 100%;
      max-width: none;
    }
    .campaign-controls {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 0.875rem;
      align-items: end;
      margin-bottom: 1.125rem;
    }
    .campaign-controls label,
    .campaign-form label {
      display: grid;
      gap: 0.375rem;
      min-width: 0;
      color: rgba(20, 22, 24, 0.58);
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
    }
    .campaign-field-circuit,
    .campaign-field-locality,
    .campaign-field-date {
      grid-column: span 2;
    }
    .campaign-field-point,
    .campaign-field-screen {
      grid-column: span 3;
    }
    .campaign-controls select,
    .campaign-controls input,
    .campaign-form input,
    .campaign-form textarea,
    .campaign-form select {
      width: 100%;
      max-width: 100%;
      min-width: 0;
      border: 1px solid rgba(20, 22, 24, 0.14);
      background: #fff;
      color: #141618;
      border-radius: 0.5rem;
      padding: 0.75rem;
      font: inherit;
    }
    .campaign-controls select,
    .campaign-controls input,
    .campaign-form input,
    .campaign-form select {
      min-height: 46px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .campaign-selection {
      margin-bottom: 1.125rem;
      color: rgba(20, 22, 24, 0.68);
      font-size: 0.875rem;
      line-height: 1.45;
      border: 1px solid rgba(20, 22, 24, 0.12);
      background: #fff;
      border-radius: 0.5rem;
      padding: 0.8rem 0.9rem;
    }
    .campaign-selection strong {
      color: #141618;
    }
    .campaign-workspace {
      border: 1px solid rgba(20, 22, 24, 0.12);
      background: #fff;
      border-radius: 0.5rem;
      padding: clamp(1rem, 2vw, 1.4rem);
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
      gap: 1rem;
      align-items: stretch;
    }
    .campaign-form,
    .campaign-preview {
      min-width: 0;
    }
    .campaign-form {
      display: grid;
      gap: 0.75rem;
      align-content: start;
    }
    .campaign-form h2,
    .campaign-preview h2 {
      margin: 0;
      color: #141618;
      font-size: 1.125rem;
      letter-spacing: 0;
    }
    .campaign-form textarea {
      min-height: 132px;
      resize: vertical;
      line-height: 1.45;
    }
    .campaign-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.625rem;
    }
    .campaign-actions .button {
      min-width: min(100%, 180px);
      cursor: pointer;
    }
    .campaign-actions .button:disabled {
      opacity: 0.5;
      cursor: default;
      transform: none;
    }
    .campaign-preview {
      display: grid;
      gap: 0.75rem;
    }
    .campaign-context {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .campaign-context span {
      max-width: 100%;
      min-width: 0;
      border: 1px solid rgba(20, 22, 24, 0.14);
      background: rgba(20, 22, 24, 0.04);
      color: rgba(20, 22, 24, 0.66);
      border-radius: 999px;
      padding: 0.45rem 0.65rem;
      font-size: 0.75rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .campaign-preview-frame {
      width: 100%;
      aspect-ratio: 16 / 9;
      min-height: 220px;
      border: 1px solid rgba(13, 59, 102, 0.24);
      background: #02080d;
      border-radius: 0.5rem;
      padding: 0.75rem;
      display: grid;
      place-items: center;
      overflow: hidden;
    }
    .campaign-preview-frame.is-vertical {
      width: min(100%, 360px);
      aspect-ratio: 9 / 16;
      min-height: 420px;
      justify-self: center;
    }
    .campaign-preview-frame img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      border-radius: 0.35rem;
      background: #071018;
    }
    .campaign-preview-empty {
      color: rgba(255, 255, 255, 0.68);
      text-align: center;
      line-height: 1.45;
      padding: 1.25rem;
    }
    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 0.5rem;
      min-height: 46px;
      padding: 0 1rem;
      font-weight: 700;
      border: 1px solid rgba(20, 22, 24, 0.14);
    }
    .button.primary {
      background: #f97316;
      color: #fffaf2;
      border-color: #f97316;
    }
    .button.secondary {
      background: #fff;
      color: #141618;
    }
    @media (max-width: 1180px) {
      .campaign-controls {
        grid-template-columns: repeat(6, minmax(0, 1fr));
      }
      .campaign-field-circuit,
      .campaign-field-locality,
      .campaign-field-date {
        grid-column: span 2;
      }
      .campaign-field-point,
      .campaign-field-screen {
        grid-column: span 3;
      }
    }
    @media (max-width: 820px) {
      .campaign-controls,
      .campaign-workspace {
        grid-template-columns: 1fr;
      }
      .campaign-controls label {
        grid-column: auto;
      }
      .campaign-actions .button {
        width: 100%;
      }
    }
  </style>

  <script is:inline src="https://www.admira.app/locations.js"></script>
  <script is:inline src="/assets/campaign-studio.js?v=20260607-1"></script>
</MainLayout>
