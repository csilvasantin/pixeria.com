---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="Campaigns · Protected Access"
  description="PixerIA Campaigns is a protected area that requires Google Single Sign-On."
  lang="en"
>
  <main class="pt-24 pb-20 min-h-screen bg-cream-50">
    <section class="max-w-5xl mx-auto px-6 py-20">
      <p class="text-orange font-medium mb-4">Campaigns</p>
      <h1 class="text-5xl md:text-7xl font-semibold tracking-tight text-charcoal max-w-4xl">
        Protected access
      </h1>
      <p class="mt-6 text-xl text-charcoal/70 max-w-3xl">
        Campaign creation and buying remain closed until the user authenticates with Google Single Sign-On.
      </p>

      <section class="mt-10 bg-white border border-charcoal/10 rounded-lg p-6 md:p-8 max-w-3xl" data-sso-required="google">
        <h2 class="text-2xl font-semibold text-charcoal mb-4">Google SSO required</h2>
        <p class="text-charcoal/70 leading-relaxed mb-5">
          This page does not load point data, screen data, previews or buying flows in public mode.
        </p>
        <ul class="grid gap-3 text-charcoal/70 mb-7">
          <li>Authentication: Google SSO.</li>
          <li>Recommended control: Cloudflare Access in front of <code>/crear-campana/</code>.</li>
          <li>Policy: allow only authorized team accounts.</li>
        </ul>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="mailto:csilvasantin@gmail.com?subject=Pixeria%20Campaigns%20Access" class="inline-flex justify-center rounded-lg bg-orange px-6 py-3 font-medium text-cream-50 hover:bg-orange-dark">
            Request access
          </a>
          <a href="/calendario/" class="inline-flex justify-center rounded-lg border border-charcoal/15 px-6 py-3 font-medium text-charcoal hover:bg-cream-100">
            Back to calendar
          </a>
        </div>
      </section>
    </section>
  </main>
</MainLayout>
