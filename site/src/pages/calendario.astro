---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Calendario de emisión | PixerIA"
  description="Mira qué se emite hoy en cada pantalla del circuito y cuántos huecos quedan disponibles para tu campaña. Mismo calendario en PixerIA, XpaceOS y admira.app."
  lang="es"
>
  <!-- HERO -->
  <section class="pt-24 pb-10 bg-[#0D3B66] text-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-white/10 text-sm tracking-[1.5px] mb-4">
        CALENDARIO DE EMISIÓN
      </div>
      <h1 class="text-5xl md:text-6xl font-semibold tracking-[-2px] mb-4">
        Qué se emite hoy
      </h1>
      <p class="max-w-2xl mx-auto text-xl text-white/80 mb-2">
        Consulta la parrilla del día de cada pantalla y cuántos huecos quedan
        <strong class="text-white">disponibles para tu campaña</strong>.
      </p>
      <p class="max-w-2xl mx-auto text-sm text-white/50">
        El mismo calendario, en tiempo real, que ven XpaceOS y admira.app.
      </p>
    </div>
  </section>

  <!-- CALENDARIO -->
  <section class="py-12 bg-cream-50">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Selectores -->
      <div class="flex flex-wrap items-end gap-4 mb-6">
        <label class="flex flex-col gap-1">
          <span class="text-xs uppercase tracking-wider text-charcoal/50 font-medium">Circuito</span>
          <select id="circuitSel" class="bg-white border border-cream-100 rounded-lg px-3 py-2 text-sm min-w-[220px]"></select>
        </label>
        <label class="flex flex-col gap-1">
          <span class="text-xs uppercase tracking-wider text-charcoal/50 font-medium">Pantalla</span>
          <select id="screenSel" class="bg-white border border-cream-100 rounded-lg px-3 py-2 text-sm min-w-[200px]"></select>
        </label>
        <label class="flex flex-col gap-1">
          <span class="text-xs uppercase tracking-wider text-charcoal/50 font-medium">Día</span>
          <input id="dateInp" type="date" class="bg-white border border-cream-100 rounded-lg px-3 py-2 text-sm" />
        </label>
      </div>

      <!-- Panel oscuro con el módulo compartido -->
      <div class="rounded-2xl p-5 md:p-7" style="background:#02080d">
        <div id="cal"></div>
      </div>

      <!-- CTA -->
      <div class="mt-8 text-center">
        <p class="text-charcoal/70 mb-3">¿Quieres emitir en estos huecos?</p>
        <a href="https://admira.app/marketplace.html" class="inline-flex items-center gap-2 bg-orange text-cream-50 px-6 py-3 rounded-lg font-medium hover:opacity-90 transition-opacity">
          Reservar en el marketplace →
        </a>
      </div>
    </div>
  </section>

  <!-- Módulo compartido del calendario de emisión -->
  <link rel="stylesheet" href="https://csilvasantin.github.io/admira-design/emission-calendar.css" />
  <script is:inline src="https://www.admira.app/locations.js"></script>
  <script is:inline src="https://csilvasantin.github.io/admira-design/emission-calendar.js"></script>
  <script is:inline>
    (function () {
      var WORKER = 'https://pixer-eleven.csilvasantin.workers.dev';
      var $ = function (s) { return document.querySelector(s); };
      var state = { stores: [], store: null, screens: [], screen: null, date: '', cal: null };
      function slug(s){return String(s||'').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'').replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');}
      function todayMadrid(){var p={};new Intl.DateTimeFormat('es-ES',{timeZone:'Europe/Madrid',year:'numeric',month:'2-digit',day:'2-digit'}).formatToParts(new Date()).forEach(function(x){p[x.type]=x.value;});return p.year+'-'+p.month+'-'+p.day;}
      function isScreen(sf){return ['pantalla','escaparate','vending','mostrador'].indexOf(sf.surface)>=0;}
      function screensOf(store){return store.surfaces.filter(isScreen).map(function(sf){return {id:slug(store.id)+'-'+slug(sf.name),name:sf.name,pixerScreens:Array.isArray(sf.pixerScreens)?sf.pixerScreens:[]};});}
      async function loadStores(){
        var list=[];
        try{ if(window.loadOmnipLocationsAsync){ var r=await window.loadOmnipLocationsAsync(); list=Array.isArray(r)?r:(r&&r.locations)||[]; } }catch(e){}
        if(!list.length&&window.loadOmnipLocations){ try{ list=window.loadOmnipLocations(); }catch(e){} }
        if(!list.length)list=window.OMNIP_LOCATIONS_DEFAULT||[];
        state.stores=list.filter(function(s){return Array.isArray(s.surfaces)&&s.surfaces.some(isScreen);});
        var sel=$('#circuitSel');sel.innerHTML='';
        state.stores.forEach(function(s){var o=document.createElement('option');o.value=s.id;o.textContent=s.name;sel.appendChild(o);});
      }
      function selectStore(id){
        state.store=state.stores.find(function(s){return s.id===id;})||state.stores[0];
        state.screens=screensOf(state.store);
        var sel=$('#screenSel');sel.innerHTML='';
        state.screens.forEach(function(sc){var o=document.createElement('option');o.value=sc.id;o.textContent=sc.name;sel.appendChild(o);});
        selectScreen(state.screens[0]&&state.screens[0].id);
      }
      function selectScreen(id){
        state.screen=state.screens.find(function(s){return s.id===id;})||state.screens[0];
        if(!state.screen){$('#cal').innerHTML='<div style="color:#75aab9;text-align:center;padding:40px">Este circuito no tiene pantallas.</div>';return;}
        var opts={workerBase:WORKER,role:'public',screen:state.screen.id,date:state.date,screenName:state.screen.name};
        if(!state.cal)state.cal=window.EmissionCalendar.mount($('#cal'),opts); else state.cal.setContext({screen:state.screen.id,date:state.date,screenName:state.screen.name});
      }
      function init(){
        if(!window.EmissionCalendar){ setTimeout(init,150); return; }
        state.date=todayMadrid();$('#dateInp').value=state.date;
        loadStores().then(function(){
          var xt=state.stores.find(function(s){return s.id==='xtanco';})||state.stores[0];
          $('#circuitSel').value=xt&&xt.id;selectStore(xt&&xt.id);
          $('#circuitSel').onchange=function(e){selectStore(e.target.value);};
          $('#screenSel').onchange=function(e){selectScreen(e.target.value);};
          $('#dateInp').onchange=function(e){state.date=e.target.value||todayMadrid();if(state.cal)state.cal.setContext({date:state.date});};
        });
      }
      if(document.readyState!=='loading')init(); else document.addEventListener('DOMContentLoaded',init);
    })();
  </script>
</MainLayout>
