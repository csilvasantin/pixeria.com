  const result = document.getElementById('result-state');
  const videoEl = document.getElementById('result-video');
  const downloadBtn = document.getElementById('download-btn');
  const usedPrompt = document.getElementById('used-prompt');

  const maxAttempts = 40; // ~ 3-4 minutes max
  let attempts = 0;

  const interval = setInterval(async () => {
    attempts++;
    if (attempts > maxAttempts) {
      clearInterval(interval);
      alert('La generación está tardando más de lo esperado. Puedes seguir sondeando manualmente o intentarlo de nuevo.');
      return;
    }

    try {
      const pollRes = await fetch(`${WORKER}/xai/video/${requestId}`);
      const data = await pollRes.json();

      // Flexible parsing of xAI response
      const status = data.status || data.state || (data.result ? 'completed' : 'processing');
      
      if (status === 'completed' || status === 'succeeded' || data.result?.url || data.url) {
        clearInterval(interval);
        
        const videoUrl = data.result?.url || data.url || data.video_url || data.output?.url;
        
        if (!videoUrl) {
          console.log('Poll response:', data);
          alert('El vídeo se generó pero no encontramos la URL. Revisa la consola.');
          return;
        }

        // Success!
        videoEl.src = videoUrl;
        downloadBtn.href = videoUrl;
        usedPrompt.textContent = originalPrompt;

        generating.classList.add('hidden');
        result.classList.remove('hidden');

        // Scroll to result
        document.getElementById('status-panel').scrollIntoView({ behavior: 'smooth', block: 'center' });

      } else if (status === 'failed' || status === 'error') {
        clearInterval(interval);
        alert('La generación falló. Prueba con un prompt diferente o más corto.');
        document.getElementById('status-panel').classList.add('hidden');
      }
      // else keep polling (processing, queued, etc.)

    } catch (e) {
      console.warn('Polling error', e);
    }
  }, 4500);
}

function resetGenerator() {
  const statusPanel = document.getElementById('status-panel');
  const videoEl = document.getElementById('result-video');

  statusPanel.classList.add('hidden');
  videoEl.src = '';

  // Clear prompt if user wants fresh start
  // document.getElementById('prompt').value = '';
  document.getElementById('generate-btn').disabled = false;
  document.getElementById('generate-btn').innerHTML = 'Generar con Grok';
}

// Init
function initCrear() {
  setupAspectButtons();
  setupExamples();

  // Default aspect button styling
  const defaultAspect = document.querySelector('[data-aspect="16:9"]');
  if (defaultAspect) {
    defaultAspect.classList.add('!border-orange', '!bg-orange', '!text-white');
  }

  // Duration label init
  const dur = document.getElementById('duration');
  if (dur) {
    document.getElementById('duration-label').textContent = dur.value + 's';
    dur.addEventListener('input', (e) => {
      document.getElementById('duration-label').textContent = e.target.value + 's';
    });
  }

  // Allow Enter in prompt to trigger (with Shift+Enter for newline)
  const promptEl = document.getElementById('prompt');
  if (promptEl) {
    promptEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        generateVideo();
      }
    });
  }

  // Keyboard shortcut hint
  console.log('%c[Pixeria Crear] Tip: Presiona Enter en el prompt para generar (Shift+Enter para salto de línea)', 'color:#888');

  // === Segmentados bridge: restore audience targeting chosen on /segmentados ===
  if (typeof initSegmentsFromStorage === 'function') {
    initSegmentsFromStorage();
  }

  // Optional: if coming from the segmented page, pre-open a specific tab/kind
  try {
    const openKind = localStorage.getItem('pixer_open_kind');
    if (openKind) {
      localStorage.removeItem('pixer_open_kind');
      // focus the relevant textarea as a hint
      const map = { video: 'video-prompt', image: 'image-prompt', audio: 'audio-prompt', music: 'music-prompt' };
      const el = document.getElementById(map[openKind] || 'video-prompt');
      if (el) setTimeout(() => el.focus(), 350);
    }
  } catch (e) {}
}

document.addEventListener('DOMContentLoaded', initCrear);
</script>