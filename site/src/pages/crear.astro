---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout 
  title="Crear con Grok | PixerIA" 
  description="Genera vídeos e imágenes con Grok de xAI por defecto. El creador oficial de Pixeria."
  lang="es"
>
  <!-- HERO -->
  <section class="pt-20 pb-12 bg-[#0D3B66] text-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-white/10 text-sm tracking-[1.5px] mb-4">
        EXCLUSIVO CON GROK
      </div>
      
      <h1 class="text-6xl md:text-7xl font-semibold tracking-[-3px] mb-4" data-god="crear.title">
        Crear Videos con Grok
      </h1>
      
      <p class="max-w-2xl mx-auto text-xl text-white/80 mb-8" data-god="crear.subtitle">
        Genera vídeos cinematográficos con inteligencia de xAI Grok. Calidad premium para pantallas y campañas.
      </p>
      
      <div class="flex items-center justify-center gap-3 text-sm">
        <div class="px-3 py-1 bg-white/10 rounded-full">Grok Imagine Video</div>
        <div class="px-3 py-1 bg-white/10 rounded-full">Hasta 15 segundos</div>
        <div class="px-3 py-1 bg-white/10 rounded-full">Alta fidelidad</div>
      </div>
    </div>
  </section>

  <!-- GENERATOR -->
  <section class="max-w-6xl mx-auto px-6 py-12">

    <!-- NUEVA SECCIÓN: CONTENIDOS SEGMENTADOS -->
    <div class="mb-8 p-6 bg-white rounded-3xl border border-cream-100 shadow">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h3 class="text-lg font-semibold tracking-tight">Contenidos Segmentados</h3>
          <p class="text-xs text-text-muted">Ajusta el contenido a los circuitos que se venden en Omnypublicity y se muestran en el gemelo digital (el globo con inventario en tiempo real). <a href="/segmentados/" class="underline hover:no-underline">Ver gemelo completo →</a></p>
        </div>
        <button onclick="resetSegments()" class="text-xs px-3 py-1 border border-orange/50 text-orange rounded-full hover:bg-orange/5">Reset</button>
      </div>

      <!-- Ubicación: Exterior o Interior -->
      <div class="mb-5">
        <div class="text-[10px] uppercase tracking-[1.5px] text-charcoal mb-2 font-medium">Tipo de Publicidad</div>
        <div class="grid grid-cols-2 gap-3">
          <div onclick="toggleSegment(this, 'ubicacion', 'exterior')" class="segment-card flex items-start gap-3 p-3 rounded-2xl border border-cream-100 hover:border-orange cursor-pointer active" data-active="true">
            <div>
              <div class="font-semibold text-sm">Publicidad Exterior</div>
              <div class="text-[11px] text-text-muted">Fuera del Xpacio (ej. pantalla de la puerta del Xtanco)</div>
            </div>
          </div>
          <div onclick="toggleSegment(this, 'ubicacion', 'interior')" class="segment-card flex items-start gap-3 p-3 rounded-2xl border border-cream-100 hover:border-orange cursor-pointer active" data-active="true">
            <div>
              <div class="font-semibold text-sm">Publicidad Interior</div>
              <div class="text-[11px] text-text-muted">Dentro del Xpacio (ej. pantalla del Metahuman)</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Género -->
      <div class="mb-5">
        <div class="text-[10px] uppercase tracking-[1.5px] text-charcoal mb-2 font-medium">Género Objetivo</div>
        <div class="flex flex-wrap gap-2">
          <div onclick="toggleSegment(this, 'genero', 'hombre')" class="segment-pill px-4 py-1.5 text-sm rounded-2xl border border-cream-100 hover:border-orange cursor-pointer active" data-active="true">Hombre</div>
          <div onclick="toggleSegment(this, 'genero', 'mujer')" class="segment-pill px-4 py-1.5 text-sm rounded-2xl border border-cream-100 hover:border-orange cursor-pointer active" data-active="true">Mujer</div>
        </div>
      </div>

      <!-- Edad (multi-select) -->
      <div>
        <div class="text-[10px] uppercase tracking-[1.5px] text-charcoal mb-2 font-medium">Rango de Edad (puedes seleccionar varios)</div>
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-2 text-xs">
          <div onclick="toggleSegment(this, 'edades', 'nino')" class="segment-pill p-2 border border-cream-100 rounded-2xl cursor-pointer active text-center" data-active="true">
            <div class="font-medium">Niño</div>
            <div class="text-[10px] text-text-muted">&lt;14 años</div>
          </div>
          <div onclick="toggleSegment(this, 'edades', 'joven')" class="segment-pill p-2 border border-cream-100 rounded-2xl cursor-pointer active text-center" data-active="true">
            <div class="font-medium">Joven</div>
            <div class="text-[10px] text-text-muted">15-30 años</div>
          </div>
          <div onclick="toggleSegment(this, 'edades', 'adulto')" class="segment-pill p-2 border border-cream-100 rounded-2xl cursor-pointer active text-center" data-active="true">
            <div class="font-medium">Adulto</div>
            <div class="text-[10px] text-text-muted">30-50 años</div>
          </div>
          <div onclick="toggleSegment(this, 'edades', 'senior')" class="segment-pill p-2 border border-cream-100 rounded-2xl cursor-pointer active text-center" data-active="true">
            <div class="font-medium">Senior</div>
            <div class="text-[10px] text-text-muted">50-65 años</div>
          </div>
          <div onclick="toggleSegment(this, 'edades', 'vejez')" class="segment-pill p-2 border border-cream-100 rounded-2xl cursor-pointer active text-center" data-active="true">
            <div class="font-medium">Vejez</div>
            <div class="text-[10px] text-text-muted">&gt;65 años</div>
          </div>
        </div>
      </div>

      <div class="mt-3 text-[10px] text-text-muted">Los prompts se ajustarán automáticamente al público seleccionado para que el contenido coincida con los circuitos disponibles en Omnypublicity y el gemelo digital.</div>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">
      
      <!-- VIDEO GENERATOR -->
      <div class="bg-white rounded-3xl shadow-xl border border-cream-100 overflow-hidden">
        <div class="bg-[#0D3B66] text-white px-6 py-4 flex items-center justify-between">
          <div class="font-semibold text-lg" data-god="crear.videoTab">Vídeo</div>
          <div class="text-xs px-3 py-1 bg-white/20 rounded-full">Siempre Grok por defecto</div>
        </div>

        <div class="p-6">
          <div class="mb-4">
            <label class="block text-sm font-medium text-charcoal mb-1.5" data-god="crear.promptLabelVideo">Describe el vídeo</label>
            <textarea id="video-prompt" class="w-full h-28 px-4 py-3 rounded-2xl border border-cream-100 text-sm" placeholder="Un plano lento al atardecer..." data-god="crear.promptPlaceholderVideo"></textarea>
          </div>

          <!-- Visual Model Selector for Video -->
          <div class="mb-4">
            <div class="text-[10px] uppercase tracking-widest text-charcoal mb-1.5" data-god="crear.modelLabel">Motor (Grok por defecto)</div>
            <div class="grid grid-cols-4 gap-1.5" id="video-models"></div>
          </div>

          <!-- Video specific controls -->
          <div class="grid grid-cols-3 gap-3 mb-6 text-sm">
            <div>
              <label class="block text-xs font-medium text-charcoal mb-1" data-god="crear.duration">Duración</label>
              <div class="flex items-center gap-2">
                <input type="range" id="video-duration" min="1" max="15" value="8" class="flex-1 accent-orange">
                <span id="video-duration-val" class="font-mono text-xs w-8 text-right">8s</span>
              </div>
            </div>
            <div>
              <label class="block text-xs font-medium text-charcoal mb-1" data-god="crear.aspect">Aspecto</label>
              <select id="video-aspect" class="w-full px-3 py-1.5 rounded-xl border text-xs">
                <option value="16:9">16:9 Horizontal</option>
                <option value="9:16">9:16 Vertical</option>
                <option value="1:1">1:1 Cuadrado</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-charcoal mb-1" data-god="crear.resolution">Resolución</label>
              <select id="video-resolution" class="w-full px-3 py-1.5 rounded-xl border text-xs">
                <option value="720p">720p</option>
                <option value="1080p">1080p</option>
              </select>
            </div>
          </div>

          <button onclick="generateVideo()" class="w-full py-3 rounded-2xl bg-orange text-white font-semibold text-sm hover:bg-orange-dark transition-all">
            <span data-god="crear.generate">Generar con Grok</span>
          </button>
        </div>
      </div>

      <!-- IMAGE GENERATOR -->
      <div class="bg-white rounded-3xl shadow-xl border border-cream-100 overflow-hidden">
        <div class="bg-[#0D3B66] text-white px-6 py-4 flex items-center justify-between">
          <div class="font-semibold text-lg" data-god="crear.imageTab">Imagen</div>
          <div class="text-xs px-3 py-1 bg-white/20 rounded-full">Siempre Grok por defecto</div>
        </div>

        <div class="p-6">
          <div class="mb-4">
            <label class="block text-sm font-medium text-charcoal mb-1.5" data-god="crear.promptLabelImage">Describe la imagen</label>
            <textarea id="image-prompt" class="w-full h-28 px-4 py-3 rounded-2xl border border-cream-100 text-sm" placeholder="Retrato cinematográfico..." data-god="crear.promptPlaceholderImage"></textarea>
          </div>

          <!-- Visual Model Selector for Image -->
          <div class="mb-4">
            <div class="text-[10px] uppercase tracking-widest text-charcoal mb-1.5" data-god="crear.modelLabel">Motor (Grok por defecto)</div>
            <div class="grid grid-cols-4 gap-1.5" id="image-models"></div>
          </div>

          <div class="grid grid-cols-2 gap-3 mb-6 text-sm">
            <div>
              <label class="block text-xs font-medium text-charcoal mb-1">Aspecto</label>
              <select id="image-aspect" class="w-full px-3 py-1.5 rounded-xl border text-xs">
                <option value="1:1">1:1 Cuadrado</option>
                <option value="16:9">16:9 Horizontal</option>
                <option value="9:16">9:16 Vertical</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-charcoal mb-1">Cantidad</label>
              <select id="image-count" class="w-full px-3 py-1.5 rounded-xl border text-xs">
                <option value="1">1 imagen</option>
                <option value="2">2 imágenes</option>
                <option value="4">4 imágenes</option>
              </select>
            </div>
          </div>

          <button onclick="generateImage()" class="w-full py-3 rounded-2xl bg-orange text-white font-semibold text-sm hover:bg-orange-dark transition-all">
            <span data-god="crear.generate">Generar con Grok</span>
          </button>
        </div>
      </div>

      <!-- AUDIO CARD -->
      <div class="bg-white rounded-3xl border border-cream-100 shadow overflow-hidden">
        <div class="px-5 py-3 bg-[#0D3B66] text-white flex items-center justify-between text-sm">
          <span class="font-semibold" data-god="crear.audioTab">Voz / Audio</span>
          <span class="text-[10px] bg-white/20 px-2 py-0.5 rounded">Grok + Eleven</span>
        </div>
        <div class="p-5 space-y-4">
          <textarea id="audio-prompt" class="w-full h-20 text-sm border rounded-2xl p-3" placeholder="..." data-god="crear.promptPlaceholderAudio"></textarea>

          <div>
            <div class="text-[10px] uppercase tracking-widest text-charcoal mb-1.5">Motor</div>
            <div class="grid grid-cols-4 gap-1.5 text-[11px]" id="audio-models"></div>
          </div>

          <div id="audio-params" class="grid grid-cols-2 gap-2 text-xs"></div>

          <button onclick="generateAudio()" class="w-full py-2 bg-orange text-white rounded-2xl text-sm font-semibold">Generar con Grok</button>
        </div>
      </div>

      <!-- MUSIC CARD -->
      <div class="bg-white rounded-3xl border border-cream-100 shadow overflow-hidden">
        <div class="px-5 py-3 bg-[#0D3B66] text-white flex items-center justify-between text-sm">
          <span class="font-semibold" data-god="crear.musicTab">Música</span>
          <span class="text-[10px] bg-white/20 px-2 py-0.5 rounded">Grok + Lyria</span>
        </div>
        <div class="p-5 space-y-4">
          <textarea id="music-prompt" class="w-full h-16 text-sm border rounded-2xl p-3" placeholder="..." data-god="crear.promptPlaceholderMusic"></textarea>

          <div>
            <div class="text-[10px] uppercase tracking-widest text-charcoal mb-1.5">Motor</div>
            <div class="grid grid-cols-4 gap-1.5 text-[11px]" id="music-models"></div>
          </div>

          <div id="music-params" class="space-y-2 text-xs"></div>

          <div class="flex gap-2">
            <button onclick="generateMusicLyrics()" class="flex-1 text-xs border py-1 rounded-2xl">Letra con Grok</button>
            <button onclick="generateMusic()" class="flex-1 bg-orange text-white rounded-2xl text-sm py-1 font-semibold">Generar</button>
          </div>
        </div>
      </div>

    </div>

    <!-- Shared Status / Result area - IMPROVED -->
    <div id="status-panel" class="hidden mt-8 max-w-5xl mx-auto bg-white rounded-3xl border border-cream-100 shadow-xl overflow-hidden">
      <!-- Generating state - improved with video preview + progress -->
      <div id="generating-state" class="p-8">
        <div id="video-preview-area" class="hidden mx-auto mb-6 w-full max-w-[720px]">
          <!-- Dynamic video generation preview mock -->
          <div class="relative aspect-video bg-[#0a0f14] rounded-2xl overflow-hidden border border-white/10 shadow-inner">
            <!-- Film grain + cinematic background -->
            <div class="absolute inset-0 bg-[radial-gradient(#ffffff08_1px,transparent_1px)] bg-[length:3px_3px]"></div>
            <!-- Moving scanlines for film feel -->
            <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(255,255,255,0.03)_50%)] bg-[length:100%_4px] animate-[scan_2s_linear_infinite]"></div>
            
            <!-- Center content -->
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <div class="text-white/50 text-xs tracking-[3px] mb-2 font-mono">GROK • RENDERING</div>
              
              <!-- Dynamic waveform / frames -->
              <div class="w-4/5 h-px bg-gradient-to-r from-transparent via-white/40 to-transparent mb-3"></div>
              
              <div class="flex gap-1.5 items-end h-9 mb-4">
                <div class="w-1.5 bg-white/30 animate-[pulse_1s_ease-in-out_infinite]" style="height:35%"></div>
                <div class="w-1.5 bg-white/50 animate-[pulse_0.8s_ease-in-out_infinite_150ms]" style="height:95%"></div>
                <div class="w-1.5 bg-white/40 animate-[pulse_1.1s_ease-in-out_infinite_80ms]" style="height:60%"></div>
                <div class="w-1.5 bg-white/70 animate-[pulse_0.7s_ease-in-out_infinite_220ms]" style="height:100%"></div>
                <div class="w-1.5 bg-white/35 animate-[pulse_1.2s_ease-in-out_infinite]" style="height:45%"></div>
                <div class="w-1.5 bg-white/55 animate-[pulse_0.9s_ease-in-out_infinite_120ms]" style="height:80%"></div>
              </div>
              
              <div class="text-[10px] text-white/30 tracking-widest">MOTION • LIGHT • COMPOSITION</div>
            </div>

            <!-- Progress overlay -->
            <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-white/10">
              <div id="video-progress-bar" 
                   class="h-1.5 bg-gradient-to-r from-orange to-[#E8B86D] transition-all duration-300"
                   style="width: 0%"></div>
            </div>

            <div class="absolute bottom-3 right-3 text-[10px] font-mono text-white/50 bg-black/40 px-1.5 rounded">
              <span id="video-progress-percent">0</span>%
            </div>
          </div>
        </div>

        <!-- Image loading mosaic (for image generation) -->
        <div id="image-preview-area" class="hidden mx-auto mb-6 w-full max-w-[720px]">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
            <div class="aspect-square bg-[#0a0f14] rounded-xl border border-white/10 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-orange/10 to-transparent animate-pulse"></div>
              <div class="absolute bottom-1 left-1 right-1 h-0.5 bg-white/20"><div class="h-0.5 bg-orange w-0 transition-all" id="img-bar-0"></div></div>
            </div>
            <div class="aspect-square bg-[#0a0f14] rounded-xl border border-white/10 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-orange/10 to-transparent animate-pulse delay-150"></div>
              <div class="absolute bottom-1 left-1 right-1 h-0.5 bg-white/20"><div class="h-0.5 bg-orange w-0 transition-all" id="img-bar-1"></div></div>
            </div>
            <div class="aspect-square bg-[#0a0f14] rounded-xl border border-white/10 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-orange/10 to-transparent animate-pulse delay-300"></div>
              <div class="absolute bottom-1 left-1 right-1 h-0.5 bg-white/20"><div class="h-0.5 bg-orange w-0 transition-all" id="img-bar-2"></div></div>
            </div>
            <div class="aspect-square bg-[#0a0f14] rounded-xl border border-white/10 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-orange/10 to-transparent animate-pulse delay-500"></div>
              <div class="absolute bottom-1 left-1 right-1 h-0.5 bg-white/20"><div class="h-0.5 bg-orange w-0 transition-all" id="img-bar-3"></div></div>
            </div>
          </div>
          <div class="text-center text-[10px] text-white/40 mt-1 tracking-widest">GENERATING THUMBNAILS WITH GROK</div>
        </div>

        <!-- General generating info -->
        <div class="text-center">
          <div class="flex justify-center items-center gap-3 mb-2">
            <div class="animate-spin w-5 h-5 border-[3px] border-orange border-t-transparent rounded-full"></div>
            <span id="generating-text" class="font-medium text-lg" data-god="crear.generating">Generando con Grok...</span>
          </div>

          <div id="request-id" class="text-xs font-mono text-text-muted mb-1"></div>
          <div id="polling-status" class="text-xs text-text-muted mb-3"></div>

          <button onclick="cancelCurrentGeneration()" 
                  class="text-xs px-3 py-1 border border-orange/50 text-orange rounded hover:bg-orange/10">
            Cancelar
          </button>
        </div>
      </div>

      <!-- Result state -->
      <div id="result-state" class="hidden">
        <!-- Header -->
        <div class="px-8 pt-6 pb-4 bg-surface border-b flex items-start justify-between">
          <div>
            <div class="text-[10px] uppercase tracking-[1.5px] text-orange">Listo • <span id="result-model"></span></div>
            <h3 id="result-title" class="text-2xl font-semibold tracking-tight"></h3>
          </div>
          <div id="result-meta" class="text-right text-xs text-text-muted"></div>
        </div>

        <!-- Content -->
        <div class="p-8" id="result-content"></div>

        <!-- Actions -->
        <div class="px-8 py-5 border-t bg-surface flex flex-wrap gap-3 items-center text-sm">
          <button onclick="downloadResult()" class="px-5 py-2 bg-charcoal text-cream-50 rounded-2xl font-medium flex items-center gap-2" data-god="crear.download">
            ⬇ Descargar
          </button>
          <button onclick="useInSignage()" class="px-4 py-2 border border-charcoal rounded-2xl hover:bg-white">Usar en Signage / Admira</button>
          <button onclick="regenerateWithSame()" class="px-4 py-2 border rounded-2xl hover:bg-white">Regenerar con mismos parámetros</button>
          <button onclick="editPromptFromResult()" class="px-4 py-2 text-orange hover:underline">Editar prompt</button>

          <div class="flex-1"></div>
          <button onclick="resetAll()" class="px-4 py-2 text-sm">Crear nuevo</button>
        </div>
      </div>
    </div>

    <!-- Recent creations -->
    <div id="recent-creations" class="hidden max-w-7xl mx-auto px-6 mt-8">
      <div class="flex items-center justify-between mb-3">
        <div class="text-xs uppercase tracking-widest text-orange">Creaciones recientes (esta sesión)</div>
        <button onclick="clearRecent()" class="text-xs text-text-muted hover:text-orange">limpiar</button>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 text-xs" id="recent-list"></div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 pb-16 text-center text-xs text-text-muted">
    <span data-god="crear.powered">Por defecto siempre con Grok (xAI). Puedes elegir otros motores.</span>
  </div>
</MainLayout>

<script>
const WORKER = 'https://pixer-eleven.csilvasantin.workers.dev';

let currentResult = { url: null, type: null };

// Visual model cards data
const MODEL_OPTIONS = {
  video: [
    { id: 'grok', label: 'Grok', sub: 'xAI', default: true, color: 'orange' },
    { id: 'veo', label: 'Veo 3', sub: 'Google', default: false },
    { id: 'veo-fast', label: 'Veo Fast', sub: 'Google', default: false },
    { id: 'kling', label: 'Kling', sub: 'Próximamente', default: false, disabled: true }
  ],
  image: [
    { id: 'grok', label: 'Grok', sub: 'xAI', default: true, color: 'orange' },
    { id: 'imagen', label: 'Imagen 4', sub: 'Google', default: false },
    { id: 'imagen-ultra', label: 'Ultra', sub: 'Google', default: false },
    { id: 'flux', label: 'Flux', sub: 'Próximamente', default: false, disabled: true }
  ],
  audio: [
    { id: 'eleven', label: 'Eleven v3', sub: 'Grok+Eleven', default: true, color: 'orange' },
    { id: 'eleven-turbo', label: 'Turbo', sub: 'Rápido', default: false },
    { id: 'grok-voice', label: 'Grok Voice', sub: 'xAI', default: false },
    { id: 'other', label: 'Otro', sub: 'Próximamente', default: false, disabled: true }
  ],
  music: [
    { id: 'lyria', label: 'Lyria 3', sub: 'Grok+Lyria', default: true, color: 'orange' },
    { id: 'lyria-pro', label: 'Lyria Pro', sub: 'Alta calidad', default: false },
    { id: 'suno', label: 'Suno', sub: 'Próximamente', default: false, disabled: true },
    { id: 'other', label: 'Otro', sub: 'Próximamente', default: false, disabled: true }
  ]
};

function createModelCards(type, containerId) {
  const container = document.getElementById(containerId);
  if (!container) return;

  container.innerHTML = '';
  const options = MODEL_OPTIONS[type] || [];

  options.forEach(opt => {
    const div = document.createElement('div');
    div.className = `p-2 border rounded-2xl text-center cursor-pointer text-[10px] transition-all ${opt.default ? 'border-orange bg-orange/10' : 'border-cream-100 hover:border-orange'} ${opt.disabled ? 'opacity-50 pointer-events-none' : ''}`;
    div.innerHTML = `
      <div class="font-semibold">${opt.label}</div>
      <div class="text-[9px] text-text-muted">${opt.sub}</div>
    `;
    if (opt.default) div.dataset.selected = 'true';

    div.onclick = () => {
      // deselect all
      container.querySelectorAll('div').forEach(d => d.classList.remove('border-orange', 'bg-orange/10'));
      div.classList.add('border-orange', 'bg-orange/10');
      container.dataset.selected = opt.id;
      renderDynamicParams(type, opt.id);
    };

    container.appendChild(div);
  });

  // set initial selected
  container.dataset.selected = options.find(o => o.default)?.id || options[0].id;
