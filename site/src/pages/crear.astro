// === SEGMENTACIÓN DE CONTENIDOS (nueva sección para Omnypublicity / gemelo) ===
let segments = {
  ubicacion: ['exterior', 'interior'],
  genero: ['hombre', 'mujer'],
  edades: ['nino', 'joven', 'adulto', 'senior', 'vejez']
};

function saveSegments() {
  try { localStorage.setItem('pixer_last_segments', JSON.stringify(segments)); } catch (e) {}
}

function toggleSegment(el, category, value) {
  if (!segments[category]) segments[category] = [];
  const idx = segments[category].indexOf(value);
  if (idx > -1) {
    segments[category].splice(idx, 1);
    el.classList.remove('active');
  } else {
    segments[category].push(value);
    el.classList.add('active');
  }
  saveSegments();
}

function resetSegments() {
  segments = {
    ubicacion: ['exterior', 'interior'],
    genero: ['hombre', 'mujer'],
    edades: ['nino', 'joven', 'adulto', 'senior', 'vejez']
  };
  document.querySelectorAll('.segment-card, .segment-pill').forEach(el => el.classList.add('active'));
  saveSegments();
}

function buildSegmentText() {
  let parts = [];
  if (segments.ubicacion && segments.ubicacion.length) {
    parts.push(`publicidad ${segments.ubicacion.join(' o ')}`);
  }
  if (segments.genero && segments.genero.length) {
    parts.push(`dirigido a ${segments.genero.join(' y ')}`);
  }
  if (segments.edades && segments.edades.length) {
    const labels = { nino: 'niños <14', joven: 'jóvenes 15-30', adulto: 'adultos 30-50', senior: 'seniors 50-65', vejez: 'vejez >65' };
    parts.push(`para ${segments.edades.map(e => labels[e]).join(', ')}`);
  }
  if (parts.length === 0) return '';
  return `Contenido segmentado para ${parts.join(', ')} en cartelería digital premium. Ajustar tono, lenguaje, imágenes y estilo específicamente para ese público objetivo y los circuitos de Omnypublicity.`;
}

function initSegmentsFromStorage() {
  try {
    const saved = localStorage.getItem('pixer_last_segments');
    if (saved) {
      const parsed = JSON.parse(saved);
      if (parsed && typeof parsed === 'object') {
        segments = { ...segments, ...parsed };
      }
    }
  } catch (e) {}
  // reflect in UI
  document.querySelectorAll('.segment-card, .segment-pill').forEach(el => {
    el.classList.remove('active');
    const isCard = el.classList.contains('segment-card');
    let val = '';
    if (isCard) {
      // infer from text content (simple)
      const txt = (el.textContent || '').toLowerCase();
      if (txt.includes('exterior')) val = 'exterior';
      if (txt.includes('interior')) val = 'interior';
    } else {
      val = (el.textContent || '').trim().toLowerCase();
      if (val === 'niño') val = 'nino';
      if (val === 'joven') val = 'joven';
      if (val === 'adulto') val = 'adulto';
      if (val === 'senior') val = 'senior';
      if (val.includes('vejez') || val.includes('>65')) val = 'vejez';
      if (val === 'hombre') val = 'hombre';
      if (val === 'mujer') val = 'mujer';
    }
    const cat = isCard ? 'ubicacion' : (val === 'hombre' || val === 'mujer' ? 'genero' : 'edades');
    if (segments[cat] && segments[cat].includes(val)) {
      el.classList.add('active');
    }
  });
}

function getEffectivePrompt(rawPrompt, type) {
  const prefix = buildSegmentText();
  if (!prefix) return rawPrompt;
  const lower = (rawPrompt || '').toLowerCase();
  if (lower.includes('segmentad') || lower.includes('público objetivo') || lower.includes('omnypublicity')) {
    return rawPrompt; // user already wrote targeting
  }
  return `${prefix}\n\n${rawPrompt || ''}`.trim();
}

