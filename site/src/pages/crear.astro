// === REAL POLLING HELPERS ===
let currentPollTimer = null;
let currentPollRequestId = null;

function clearCurrentPoll() {
  if (currentPollTimer) {
    clearInterval(currentPollTimer);
    currentPollTimer = null;
  }
  currentPollRequestId = null;
}

function cancelCurrentGeneration() {
  clearCurrentPoll();
  hideVideoGeneratingPreview();
  const panel = document.getElementById('status-panel');
  const gen = document.getElementById('generating-state');
  if (panel) panel.classList.add('hidden');
  if (gen) gen.classList.remove('hidden');
  const statusText = document.getElementById('polling-status');
  if (statusText) statusText.textContent = 'Cancelado por el usuario';
}

async function pollUntilDone(requestId, isVeo = false, onUpdate = null) {
  return new Promise((resolve, reject) => {
    let attempts = 0;
    const maxAttempts = 45; // ~ 3.5 minutes
    const intervalMs = 4500;
    const startTime = Date.now();

    currentPollRequestId = requestId;

    currentPollTimer = setInterval(async () => {
      attempts++;
      const elapsed = Math.round((Date.now() - startTime) / 1000);

      try {
        let statusRes;
        let data;

        if (isVeo) {
          statusRes = await fetch(`${WORKER}/veo/status/${encodeURIComponent(requestId)}`);
        } else {
          statusRes = await fetch(`${WORKER}/xai/video/${encodeURIComponent(requestId)}`);
        }

        data = await statusRes.json();

        // Calculate estimated progress (capped at 95% until we get the final result)
        let estimatedProgress = Math.min(95, Math.floor((elapsed / 75) * 100)); // assume ~75s average for Grok video

        if (onUpdate) onUpdate(data, elapsed, attempts, estimatedProgress);

        const status = (data.status || data.state || '').toLowerCase();
        const isDone = status === 'completed' || status === 'succeeded' || status === 'done' || data.result || data.url || data.video_url;

        if (isDone) {
          clearCurrentPoll();

          let videoUrl = null;
          if (data.result?.url) videoUrl = data.result.url;
          else if (data.url) videoUrl = data.url;
          else if (data.video_url) videoUrl = data.video_url;
          else if (data.output?.url) videoUrl = data.output.url;

          if (videoUrl) {
            // Jump to 100% on success
            if (onUpdate) onUpdate(data, elapsed, attempts, 100);
            resolve({ url: videoUrl, raw: data });
          } else {
            reject(new Error('Video generado pero no se encontró la URL'));
          }
          return;
        }

        if (status === 'failed' || status === 'error' || status === 'cancelled') {
          clearCurrentPoll();
          reject(new Error(data.error || `Generación fallida (${status})`));
          return;
        }

        if (attempts >= maxAttempts) {
          clearCurrentPoll();
          reject(new Error('Tiempo de espera agotado.'));
          return;
        }

      } catch (err) {
        console.warn('Polling attempt error', err);
        if (attempts >= maxAttempts) {
          clearCurrentPoll();
          reject(err);
        }
      }
    }, intervalMs);
  });
}

// Generate Video with REAL polling
async function generateVideo() {
  const raw = document.getElementById('video-prompt').value.trim();
  if (!raw) return alert('Prompt requerido');
  const prompt = getEffectivePrompt(raw, 'video');

  const model = getSelectedModel('video');
  const statusPanel = document.getElementById('status-panel');
  const gen = document.getElementById('generating-state');
  const res = document.getElementById('result-state');
  const pollingStatus = document.getElementById('polling-status');
  const generatingText = document.getElementById('generating-text');

  clearCurrentPoll();

  statusPanel.classList.remove('hidden');
  gen.classList.remove('hidden');
  res.classList.add('hidden');
  if (pollingStatus) pollingStatus.textContent = '';

  const duration = document.getElementById('video-duration')?.value || 8;
  const aspect = document.getElementById('video-aspect')?.value || '16:9';
  const resolution = document.getElementById('video-res')?.value || '720p';

  lastGenerationParams = { type: 'video', prompt, model, params: { duration, aspect, resolution } };

  try {
    let endpoint = '/xai/video';
    let body = { prompt, duration: Number(duration), aspect_ratio: aspect, resolution };
    let isVeo = false;

    if (model === 'veo' || model === 'veo-fast') {
      endpoint = '/veo/generate';
      body = {
        prompt,
        durationSeconds: Number(duration),
        aspectRatio: aspect,
        resolution,
        model: model === 'veo-fast' ? 'veo-3.0-fast-generate-001' : 'veo-3.0-generate-001'
      };
      isVeo = true;
    }

    if (generatingText) generatingText.textContent = `Generando con ${model.toUpperCase()}...`;

    const startRes = await fetch(`${WORKER}${endpoint}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const startData = await startRes.json();

    const requestId = startData.id || startData.request_id || startData.name || startData.operation || startData.requestId;
    if (!requestId) throw new Error('No se recibió ID de la generación');

    document.getElementById('request-id').textContent = `ID: ${requestId} • ${model}`;

    // Show the cinematic video preview + progress bar
    showVideoGeneratingPreview();

    // Real polling with progress bar
    const pollPromise = pollUntilDone(
      requestId,
      isVeo,
      (data, elapsedSeconds, attempt, progress) => {
        const status = (data.status || data.state || 'processing').toLowerCase();
        
        // Estimate remaining time (rough, based on progress)
        let remainingText = '';
        if (progress && progress > 5) {
          const estimatedTotal = Math.round(elapsedSeconds / (progress / 100));
          const remaining = Math.max(0, estimatedTotal - elapsedSeconds);
          remainingText = ` • ~${remaining}s restantes`;
        }

        if (pollingStatus) {
          pollingStatus.textContent = `${status} • ${elapsedSeconds}s${remainingText}`;
        }
        if (generatingText) {
          generatingText.textContent = `Procesando con ${model.toUpperCase()}...`;
        }

        // Drive the visual preview progress bar
        if (progress !== undefined) {
          updateVideoProgress(progress, `${status}`);
        }
      }
    );

    const result = await pollPromise;

    // Success - hide the loading preview and show the real video
    hideVideoGeneratingPreview();
    gen.classList.add('hidden');
    showResult('video', result.url, prompt, model, { duration, aspect, resolution });

  } catch (e) {
    clearCurrentPoll();
    hideVideoGeneratingPreview();
    alert('Error durante la generación: ' + (e.message || e));
    statusPanel.classList.add('hidden');
  }
}

