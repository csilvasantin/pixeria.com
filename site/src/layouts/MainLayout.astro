---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'es' | 'en';
}

const { 
  title = 'PixerIA', 
  description = 'Contenido para cartelería digital que emociona de verdad.',
  lang = 'es' 
} = Astro.props;

const isSpanish = lang === 'es';
const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    
    <title>{title} — PixerIA</title>
  </head>
  <body class="bg-cream-50 text-charcoal antialiased">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-cream-50/95 backdrop-blur-md border-b border-cream-100">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between gap-4">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 shrink-0">
          <div class="w-8 h-8 rounded-full bg-orange flex items-center justify-center">
            <span class="text-cream-50 font-semibold text-lg tracking-tighter">P</span>
          </div>
          <span class="font-semibold text-xl tracking-tight">PixerIA</span>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden lg:flex items-center gap-7 text-sm">
          <a href="/#como-funciona" class="hover:text-orange transition-colors">
            {isSpanish ? 'Método' : 'Method'}
          </a>
          <a href="/crear/" class={`hover:text-orange transition-colors font-medium ${path.startsWith('/crear/') ? 'text-orange' : ''}`}>
            {isSpanish ? 'Crear' : 'Create'}
          </a>
          <a href="/crear-campana/" class={`hover:text-orange transition-colors font-medium ${path.startsWith('/crear-campana') || path.startsWith('/calendario') ? 'text-orange' : ''}`}>
            {isSpanish ? 'Campañas' : 'Campaigns'}
          </a>
        </div>

        <div class="flex items-center gap-3 shrink-0">
          <!-- Language Switcher -->
          <div class="flex items-center rounded-full bg-surface p-1 text-xs font-semibold" aria-label="Seleccion de idioma">
            <a 
              href="/" 
              class={`px-3 py-1 rounded-full transition-all ${lang === 'es' ? 'bg-orange text-cream-50' : 'hover:bg-cream-100'}`}
            >
              ESP
            </a>
            <a 
              href="/en/"
              class={`px-3 py-1 rounded-full transition-all ${lang === 'en' ? 'bg-orange text-cream-50' : 'hover:bg-cream-100'}`}
            >
              ENG
            </a>
          </div>

          <!-- CTA -->
          <a 
            href="mailto:csilvasantin@gmail.com?subject=Pixeria"
            class="hidden sm:inline-flex px-5 py-2 rounded-full bg-orange text-cream-50 text-sm font-medium hover:bg-orange-dark transition-colors"
          >
            {isSpanish ? 'Contacto' : 'Contact'}
          </a>
          <button
            id="pixeriaMenuToggle"
            class="lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-full border border-cream-100 bg-white text-charcoal"
            type="button"
            aria-label={isSpanish ? 'Abrir menu' : 'Open menu'}
            aria-expanded="false"
          >
            <span class="sr-only">{isSpanish ? 'Abrir menu' : 'Open menu'}</span>
            <span class="block h-3.5 w-4 border-y-2 border-current"></span>
          </button>
        </div>
      </div>
      <div id="pixeriaMobileMenu" class="hidden lg:hidden border-t border-cream-100 bg-cream-50 px-6 py-4 shadow-lg">
        <div class="mx-auto flex max-w-7xl flex-col gap-2 text-sm font-medium">
          <a href="/#como-funciona" class="rounded-lg px-3 py-3 hover:bg-cream-100">
            {isSpanish ? 'Método' : 'Method'}
          </a>
          <a href="/crear/" class={`rounded-lg px-3 py-3 hover:bg-cream-100 ${path.startsWith('/crear/') ? 'text-orange' : ''}`}>
            {isSpanish ? 'Crear' : 'Create'}
          </a>
          <a href="/crear-campana/" class={`rounded-lg px-3 py-3 hover:bg-cream-100 ${path.startsWith('/crear-campana') || path.startsWith('/calendario') ? 'text-orange' : ''}`}>
            {isSpanish ? 'Campañas' : 'Campaigns'}
          </a>
          <a href="mailto:csilvasantin@gmail.com?subject=Pixeria" class="mt-2 rounded-lg bg-orange px-3 py-3 text-center text-cream-50">
            {isSpanish ? 'Contacto' : 'Contact'}
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <!-- Footer -->
    <footer class="bg-charcoal text-cream-100 py-12">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6 text-sm">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-full bg-orange flex items-center justify-center">
              <span class="text-cream-50 text-xs font-bold">P</span>
            </div>
            <span class="text-cream-50">PixerIA</span>
          </div>
          
          <div class="text-cream-100/60" data-god="footer.tagline">
            © {new Date().getFullYear()} PixerIA. {isSpanish ? 'Contenido que cuenta historias.' : 'Content that tells stories.'}
          </div>
        </div>
      </div>
    </footer>

    <!-- GOD MODE — Live text overrides from /god (secure, only affects public pages) -->
    <script>
      (function() {
        const toggle = document.getElementById('pixeriaMenuToggle');
        const menu = document.getElementById('pixeriaMobileMenu');
        if (!toggle || !menu) return;
        function setOpen(open) {
          menu.classList.toggle('hidden', !open);
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
        toggle.addEventListener('click', () => setOpen(menu.classList.contains('hidden')));
        menu.addEventListener('click', (event) => {
          if (event.target instanceof HTMLAnchorElement) setOpen(false);
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setOpen(false);
        });
        window.addEventListener('resize', () => {
          if (window.innerWidth >= 1024) setOpen(false);
        });
      })();

      (function() {
        // Don't run on the God editor itself
        if (location.pathname.startsWith('/god')) return;

        const WORKER = 'https://pixer-eleven.csilvasantin.workers.dev';

        function applyValue(el, value) {
          if (!el || value == null) return;
          const useHtml = el.hasAttribute('data-god-html');
          if (useHtml) {
            el.innerHTML = String(value);
          } else {
            el.textContent = String(value);
          }
        }

        function applyOverrides(overrides) {
          if (!overrides || typeof overrides !== 'object') return;

          function walk(obj, prefix = '') {
            for (const [key, val] of Object.entries(obj)) {
              const path = prefix ? `${prefix}.${key}` : key;

              if (val && typeof val === 'object' && !Array.isArray(val)) {
                walk(val, path);
              } else if (Array.isArray(val)) {
                val.forEach((item, index) => {
                  if (item && typeof item === 'object') {
                    walk(item, `${path}.${index}`);
                  } else {
                    // primitive in array (rare)
                    applyToPath(`${path}.${index}`, item);
                  }
                });
              } else {
                applyToPath(path, val);
              }
            }
          }

          function applyToPath(path, value) {
            const selector = `[data-god="${path}"]`;
            document.querySelectorAll(selector).forEach(el => applyValue(el, value));
          }

          walk(overrides);
        }

        // Fetch and apply God Mode overrides
        fetch(`${WORKER}/god/content`, { cache: 'no-store' })
          .then(r => r.ok ? r.json() : null)
          .then(ov => {
            if (ov) {
              applyOverrides(ov);
              // Optional: expose for debugging or God preview reuse
              window.PIXER_OVERRIDES = ov;
            }
          })
          .catch(() => { /* silent fail — use baked content */ });
      })();
    </script>
  </body>
</html>
